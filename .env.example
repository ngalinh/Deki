# ===== Basso Auth =====
# Endpoint verify session cookie từ basso.vn (Xeko style)
BASSO_AUTH_URL=https://ai.basso.vn/platform/api/auth/session

# ===== MySQL =====
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=deki
MYSQL_PASSWORD=
MYSQL_DATABASE=basso_platform

# ===== Permissions =====
# Email super admin Deki (lowercase, không qua bảng permissions)
DEKI_SUPER_ADMIN=linh@basso.vn

# ===== Server =====
# Platform Basso đã gán PORT cho bot này → giữ nguyên
PORT=4102

# ===== Partner API (cho Zalo CRM gọi tra khách theo SĐT) =====
# Chuỗi bí mật bất kỳ; phải TRÙNG với DEKI_API_KEY khai báo bên Zalo CRM.
DEKI_API_KEY=

# ===== Basso Partner API (mở link đơn hàng từ mã đơn — giống Zalo CRM) =====
# Bấm mã đơn ở tab Đơn hàng → tra id nội bộ → mở basso.vn/basso/customer_order/detail/{id}.
# Lấy cùng giá trị Zalo CRM đang dùng. Thiếu 1 trong 4 → tính năng báo "chưa cấu hình".
BASSO_API_URL=https://basso.vn
BASSO_API_KEY=
BASSO_EMAIL=
BASSO_PASS=
